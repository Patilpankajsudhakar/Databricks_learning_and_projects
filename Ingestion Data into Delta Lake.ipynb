     "title": ""
    }
   },
   "outputs": [],
   "source": [
    "# Create a file called employees.csv in the specified catalog.schema.volume\n",
    "\n",
    "import pandas as pd\n",
    "data =[\n",
    "    [\"1111\",\"kristi\",\"USA\",\"Manager\"],\n",
    "    [\"2222\",\"Pankaj\",\"India\",\"Deveplor\"]\n",
    "]\n",
    "\n",
    "columns = ['ID',\"Firstname\",\"Country\",\"Title\"]\n",
    "df  = pd.DataFrame(data = data, columns = columns)\n",
    "file_path = f\"/Volumes/{catalog_name}/{schema_name}{volume_name}/employees_sample.csv\"\n",
    "df.to_csv(file_path, index= False)"
   ]
  },
